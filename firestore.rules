rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Allowlist is hardcoded here rather than in a config doc: there is no
    // bootstrap problem (no doc must exist before first sign-in), and adding
    // a user is a one-line rules redeploy for a two-person workspace.
    function isAllowed() {
      return request.auth != null
        && request.auth.token.email_verified
        && request.auth.token.email in ['amidha111@gmail.com'];
    }

    match /opportunities/{oppId} {
      allow read, create, update, delete: if isAllowed();
    }

    match /activities/{activityId} {
      allow read, create, delete: if isAllowed(); // delete only for record cascade
      allow update: if false;                     // entries are never edited
    }

    match /contacts/{contactId} {
      allow read, create, update, delete: if isAllowed();
    }

    match /accounts/{accountId} {
      allow read, create, update, delete: if isAllowed();
    }
  }
}
