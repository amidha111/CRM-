rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedInVerified() {
      return request.auth != null
        && request.auth.token.email_verified
        && request.auth.token.email is string;
    }

    function isAdmin() {
      return isSignedInVerified()
        && request.auth.token.email == 'amidha111@gmail.com';
    }

    function isAllowed() {
      return isAdmin()
        || (
          isSignedInVerified()
          && exists(/databases/$(database)/documents/allowedUsers/$(request.auth.token.email))
        );
    }

    match /opportunities/{oppId} {
      allow read, create, update, delete: if isAllowed();
    }

    match /activities/{activityId} {
      allow read, create, delete: if isAllowed(); // delete only for record cascade
      allow update: if false;                     // entries are never edited
    }

    match /contacts/{contactId} {
      allow read, create, update, delete: if isAllowed();
    }

    match /accounts/{accountId} {
      allow read, create, update, delete: if isAllowed();
    }

    match /allowedUsers/{email} {
      allow read: if isAdmin();
      allow create, update: if isAdmin()
        && email != 'amidha111@gmail.com'
        && request.resource.data.email == email;
      allow delete: if isAdmin()
        && email != 'amidha111@gmail.com';
    }
  }
}
